{
    "name": "jorisnoo/craft-modules",
    "type": "craft-module",
    "authors": [
        {
            "name": "Joris Noordermeer",
            "email": "contact@noordermeer.ch"
        }
    ],
    "autoload": {
        "psr-4": {
            "Noo\\CraftModules\\": "src/"
        }
    },
    "require": {
        "php": "^8.2",
        "craftcms/cms": "^5.0.0",
        "jorisnoo/craft-sitemap": "dev-main",
        "jorisnoo/craft-remote-sync": "dev-main",
        "jorisnoo/craft-seo-preview": "dev-main"
    },
    "require-dev": {
        "roave/security-advisories": "dev-latest",
        "laravel/pint": ">=1.18.1",
        "pestphp/pest": "^4.4"
    },
    "scripts": {
        "lint": "pint"
    },
    "config": {
        "allow-plugins": {
            "yiisoft/yii2-composer": true,
            "craftcms/plugin-installer": true,
            "pestphp/pest-plugin": true
        }
    }
}
