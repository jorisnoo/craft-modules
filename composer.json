{
    "name": "jorisnoo/craft-modules",
    "type": "craft-module",
    "license": "MIT",
    "keywords": [
        "craft",
        "cms",
        "craftcms",
        "module"
    ],
    "authors": [
        {
            "name": "Joris Noordermeer",
            "email": "contact@noordermeer.ch",
            "homepage": "https://github.com/jorisnoo"
        }
    ],
    "autoload": {
        "psr-4": {
            "Noo\\CraftModules\\": "src/"
        }
    },
    "require": {
        "php": "^8.2",
        "craftcms/cms": "^5.9.0",
        "jorisnoo/craft-sitemap": "^1.0.0",
        "jorisnoo/craft-remote-sync": "^2.0.0",
        "jorisnoo/craft-seo-preview": "^1.0.0",
        "jorisnoo/craft-twig-helpers": "^1.0.0"
    },
    "require-dev": {
        "roave/security-advisories": "dev-latest",
        "laravel/pint": ">=1.18.1",
        "pestphp/pest": "^4.4"
    },
    "scripts": {
        "lint": "pint"
    },
    "config": {
        "allow-plugins": {
            "yiisoft/yii2-composer": true,
            "craftcms/plugin-installer": true,
            "pestphp/pest-plugin": true
        }
    }
}
